msgstr "Registreringsavgift %(number)d %(user)s per %(event)s"

msgid "Annual membership fee"
msgstr "Årlig medlemsavgift"

#, python-format
msgid "Membership fee of %(user)s for %(year)s"
msgstr "Andel %(user)s per %(year)s"

#, python-format
