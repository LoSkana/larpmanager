msgstr "Tämä kriteeri koskee vain hahmoja, joilla on kaikki vaaditut kyvyt"

#, python-format
msgid ""
"To confirm it, please pay the following amount as soon as possible: "
"%(amount)s"
msgstr ""
"Vahvistaaksesi sen, maksa seuraava summa mahdollisimman pian: %(amount)s"

msgid ""
"Track upcoming event deadlines and identify members who need to be followed "
